# Copy to .env and fill in values before running docker compose.
# Both keys must be non-empty strings (any value works for local use).
LLAMA_API_KEY=change-me-llama
GRANITE_API_KEY=change-me-granite

# Optional: HuggingFace Hub token. Not required for public Granite models, but
# avoids the "unauthenticated requests" warning and gives higher rate limits /
# faster downloads. Create one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Which services to run. Remove a name to skip that service group.
#   base — llama.cpp backend + chunking proxy  (port 8700)
#   plus — PyTorch plus model + proxy          (port 8701, needs ~8 GB RAM)
#   nar  — non-autoregressive model            (port 8702, needs ~4 GB RAM)
# Example (base + NAR only, no plus): COMPOSE_PROFILES=base,nar
COMPOSE_PROFILES=base,plus,nar
